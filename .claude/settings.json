{
  "worktree": {
    "baseRef": "fresh"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python ${CLAUDE_PROJECT_DIR}/.claude/hooks/session_branch_guard.py",
            "statusMessage": "Checking git branch...",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python ${CLAUDE_PROJECT_DIR}/.claude/hooks/check_edited_file.py",
            "statusMessage": "Quality gate on edited file...",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python ${CLAUDE_PROJECT_DIR}/.claude/hooks/cleanup_session_servers.py",
            "statusMessage": "Stopping this worktree's dev servers...",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
