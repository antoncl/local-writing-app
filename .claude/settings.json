{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python ${CLAUDE_PROJECT_DIR}/.claude/hooks/check_edited_file.py",
            "statusMessage": "Quality gate on edited file...",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
