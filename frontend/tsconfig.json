{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    // @xyflow/svelte's types reference PromiseWithResolvers (ES2024); pull in
    // just that lib slice on top of the ES2022 target + DOM defaults.
    "lib": ["ES2022", "ES2024.Promise", "DOM", "DOM.Iterable"],
    "moduleResolution": "Bundler",
    "strict": true,
    "isolatedModules": true,
    "useDefineForClassFields": true,
    "allowSyntheticDefaultImports": true,
    "types": ["svelte"],
    "verbatimModuleSyntax": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.svelte"],
  "references": []
}
